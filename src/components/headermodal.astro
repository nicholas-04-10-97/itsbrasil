---
import "../styles/headerpopup.css";
---

<a href="#" class="location-btn" id="openLocation">Salvador, BA ▾</a>

<!-- Modal -->
<div id="locationModal" class="modal">
  <div class="modal-content">
    <span class="close-btn" id="closeLocation">&times;</span>

<div class="PopupContent">
      <!-- Logo -->
<img src="icons/its-logo2.png" alt="ITS_dark_logo" class="PopupLogo"/>
  <div>
    <!-- Search -->
    <div class="search-container"><img src="icons/search-13-xxl.png">
      <input 
      type="text" 
      id="searchCity" 
      placeholder="Qual sua cidade?"
      class="search-input"
    />
  </div>
<hr class="meu-separador" />

    <ul id="cityList" class="city-list">
      <li data-city="salvador">Salvador, BA</li>
      <li data-city="catu">Catu, BA</li>
      <li data-city="cachoeira">Cachoeira, BA</li>
      <li data-city="esplanada">Esplanada, BA</li>
    </ul>
  </div>
</div>
</div>


<script>
  const openBtn = document.getElementById("openLocation");
  const modal = document.getElementById("locationModal");
  const closeBtn = document.getElementById("closeLocation");
  const searchInput = document.getElementById("searchCity");
  const items = document.querySelectorAll("#cityList li");

  // Open modal
  openBtn.addEventListener("click", (e) => {
    e.preventDefault();
    modal.classList.add("active");
  });

  // Close modal
  closeBtn.addEventListener("click", () => {
    modal.classList.remove("active");
  });

    // CLOSE CLICKING OUTSIDE
  modal.addEventListener("click", (e) => {
    if (e.target === modal) {
      modal.classList.remove("active");
    }
  });

  // Search
  searchInput.addEventListener("keyup", () => {
    const value = searchInput.value.toLowerCase();
    items.forEach(item => {
      item.style.display = item.textContent.toLowerCase().includes(value)
        ? ""
        : "none";
    });
  });

  // Select city
  items.forEach(item => {
    item.addEventListener("click", () => {
      const city = item.dataset.city;

      localStorage.setItem("selectedCity", city);

      openBtn.textContent = item.textContent + " ▾";
      modal.classList.remove("active");

      // 🔥 GLOBAL EVENT
      window.dispatchEvent(new CustomEvent("cityChanged", {
        detail: { city }
      }));
    });
  });

  // Load saved city on reload
  document.addEventListener("DOMContentLoaded", () => {
    const savedCity = localStorage.getItem("selectedCity");
    if (savedCity) {
      const match = [...items].find(i => i.dataset.city === savedCity);
      if (match) {
        openBtn.textContent = match.textContent + " ▾";
      }
    }
  });



</script>